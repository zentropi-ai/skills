    key = require_key(args)
    handle_response(
        request("DELETE", f"/v1/labelers/{args.labeler_id}/tests/{args.test_id}", key),
        args.json,
    )


def cmd_tests_delete_all(args):
    key = require_key(args)
    handle_response(request("DELETE", f"/v1/labelers/{args.labeler_id}/tests", key), args.json)


def cmd_benchmark(args):
    key = require_key(args)
    url = f"{api_base()}/v1/labelers/{args.labeler_id}/benchmark"
    params = {}
    if args.version is not None:
        params["version_id"] = args.version
    results = []
    try:
        with client() as c:
            with c.stream("POST", url, headers=auth_headers(key), params=params) as resp:
                if resp.status_code == 401:
                    die("authentication failed (401). Check your API key.", code=3)
                if resp.status_code >= 400:
                    body = resp.read().decode("utf-8", "replace")
                    die(f"benchmark failed ({resp.status_code}): {body}")
                for line in resp.iter_lines():
                    if not line or not line.startswith("data: "):
                        continue
                    payload = line[len("data: "):]
                    try:
                        obj = json.loads(payload)
                    except json.JSONDecodeError:
                        continue
                    results.append(obj)
                    if not args.json:
                        line = _summarize_result(obj)
                        if line:
                            print(line)
    except httpx.RequestError as e:
        die(f"network error: {e}")

    if args.json:
        print(json.dumps(results, indent=2))


def _summarize_result(obj):
    t = obj.get("type")
    if t == "test":
        exp = obj.get("expected_label")
        pred = obj.get("predicted_label")
        mark = "ok " if exp == pred else "MISS"
        conf = obj.get("confidence")
        text = (obj.get("content_text") or "")[:50]
        return f"[{mark}] expected={exp} predicted={pred} conf={conf}  {text}"
    if t == "error":
        return f"[ERR ] sample={obj.get('sample_id')} {obj.get('error')}"
    if t == "summary":
        return (
            "\n--- summary ---\n"
            f"samples: {obj.get('num_samples', 0)}  "
            f"scored: {obj.get('num_scored', 0)}  "
            f"errored: {obj.get('num_errored', 0)}\n"
            f"precision: {obj.get('precision', 0):.3f}  "
            f"recall: {obj.get('recall', 0):.3f}  "
            f"f1: {obj.get('f1', 0):.3f}  "
            f"accuracy: {obj.get('accuracy', 0):.3f}\n"
            f"tp={obj.get('tp', 0)} fp={obj.get('fp', 0)} "
            f"tn={obj.get('tn', 0)} fn={obj.get('fn', 0)}"
        )
    if t == "done":
        return None
    return json.dumps(obj)


# Optimizer effort tiers, matching the names and behavior shown in the web UI.
# The value is the optimizer's effort budget in seconds (max_time_seconds), an
# approximate runtime, not a wall-clock guarantee:
#   basic (120s, ~2 min):  reformat your labeling criteria.
#   pro   (600s, ~10 min): tune to fit your tests.
#   guru  (1800s, ~30 min): deeply tune with analysis.
OPTIMIZER_TIERS = {"basic": 120, "pro": 600, "guru": 1800}


def cmd_optimize_start(args):
    key = require_key(args)
    body = {"max_time_seconds": OPTIMIZER_TIERS[args.tier], "version_id": args.version}
    handle_response(
        request("POST", f"/v1/labelers/{args.labeler_id}/optimize", key, json_body=body),
        args.json,
    )


def cmd_optimize_status(args):
    key = require_key(args)
    handle_response(
        request("GET", f"/v1/labelers/{args.labeler_id}/optimize/{args.job_id}", key),
        args.json,
    )


def cmd_optimize_discard(args):
    key = require_key(args)
    handle_response(
        request("POST", f"/v1/labelers/{args.labeler_id}/optimize/{args.job_id}/discard", key),
        args.json,
    )


def cmd_fork(args):
    key = require_key(args)
    body = {"version_id": args.version, "clone_test_samples": args.clone_tests}
    if args.name is not None:
        body["name"] = args.name
    if args.visibility is not None:
        body["visibility"] = args.visibility
    handle_response(
        request("POST", f"/v1/labelers/{args.labeler_id}/fork", key, json_body=body),
        args.json,
    )


def cmd_star(args):
    key = require_key(args)
    if args.status:
        handle_response(request("GET", f"/v1/labelers/{args.labeler_id}/star", key), args.json)
    else:
        handle_response(request("POST", f"/v1/labelers/{args.labeler_id}/star", key), args.json)


def cmd_check(args):
    """Spot-check a labeler against ad-hoc content via the /v1 build API."""
    key = require_key(args)
    if not args.text and not args.image and not args.video:
        die("provide --text, --image, or --video to spot-check.")
    body = {}
    if args.text is not None:
        body["content_text"] = args.text
    try:
        if args.image is not None:
            body["content_image"] = _media_to_data_url(args.image, "image")
        if args.video is not None:
            body["content_video"] = _media_to_data_url(args.video, "video")
    except ValueError as e:
        die(str(e))
    params = {}
    if args.version is not None:
        params["version_id"] = args.version
    handle_response(
        request(
            "POST",
            f"/v1/labelers/{args.labeler_id}/check",
            key,
            json_body=body,
            params=params,
        ),
        args.json,
    )


def cmd_label(args):
    """Single-shot labeling via the inference API (api.zentropi.ai)."""
    key = require_key(args)
    if not args.text and not args.image and not args.video:
        die("provide --text, --image, or --video (single-shot inference needs content).")
    if args.criteria is not None and args.labeler_id is not None:
        die("provide either a labeler_id or --criteria for ad-hoc labeling, not both.")
    if args.criteria is None and args.labeler_id is None:
        die("provide a labeler_id, or --criteria to label against ad-hoc policy text.")
    body = {"model": args.model}
    if args.criteria is not None:
        if args.version is not None:
            die("--version cannot be combined with --criteria (ad-hoc labeling has no versions).")
        body["criteria_text"] = args.criteria
    else:
        body["labeler_id"] = args.labeler_id
        if args.version is not None:
            body["labeler_version_id"] = args.version
    if args.text is not None:
        body["content_text"] = args.text
    try:
        if args.image is not None:
            body["content_image"] = _media_to_data_url(args.image, "image")
        if args.video is not None:
            body["content_video"] = _media_to_data_url(args.video, "video")
    except ValueError as e:
        die(str(e))
    url = f"{inference_base()}/v1/label"
    try:
        with client() as c:
            resp = c.post(url, headers=auth_headers(key), json=body)
    except httpx.RequestError as e:
        die(f"network error: {e}")
    handle_response(resp, args.json)


# ----------------------------------------------------------------------------
# Argument parsing
# ----------------------------------------------------------------------------

def build_parser():
    _version = __version__
    p = argparse.ArgumentParser(prog="zentropi-labeler", description="Zentropi public API CLI")
    p.add_argument("--version", action="version", version=f"%(prog)s {_version}")
    p.add_argument("--json", action="store_true", help="Output raw JSON.")
    p.add_argument("--api-key", help="Override the API key for this invocation.")
    sub = p.add_subparsers(dest="command", required=True)

    # login / logout
    sp = sub.add_parser(
        "login",
        help="Store an API key. Omit the key to be prompted securely (recommended).",
    )
    sp.add_argument(
        "key",
        nargs="?",
        default=None,
        help="A zt_ API key. Omit to enter it via a hidden prompt (avoids shell history).",
    )
    sp.set_defaults(func=cmd_login)

    sp = sub.add_parser("logout", help="Remove the stored API key.")
    sp.set_defaults(func=cmd_logout)

    # account
    sp = sub.add_parser("account", help="Show account info.")
    sp.set_defaults(func=cmd_account)

    # labeler lifecycle (top-level; the binary is the noun)
    s = sub.add_parser("list", help="List your labelers.")
    s.add_argument("--skip", type=int, default=0)
    s.add_argument("--limit", type=int, default=100)
    s.set_defaults(func=cmd_labelers_list)

    s = sub.add_parser("get", help="Get a labeler.")
    s.add_argument("id")
    s.set_defaults(func=cmd_labelers_get)

    s = sub.add_parser("create", help="Create a labeler.")
    s.add_argument("--name")
    s.add_argument("--description")
    s.add_argument("--criteria", help="Draft criteria text.")
    s.add_argument("--visibility", choices=["public", "private"])
    s.set_defaults(func=cmd_labelers_create)

    s = sub.add_parser("update", help="Update a labeler.")
    s.add_argument("id")
    s.add_argument("--name")
    s.add_argument("--description")
    s.add_argument("--criteria", help="Draft criteria text.")
    s.add_argument("--visibility", choices=["public", "private"])
    s.set_defaults(func=cmd_labelers_update)

    s = sub.add_parser("delete", help="Delete a labeler.")
    s.add_argument("id")
    s.set_defaults(func=cmd_labelers_delete)

    # versions
    sp = sub.add_parser("versions", help="Manage labeler versions.")
    vsub = sp.add_subparsers(dest="subcommand", required=True)

    s = vsub.add_parser("list", help="List versions.")
    s.add_argument("labeler_id")
    s.set_defaults(func=cmd_versions_list)

    s = vsub.add_parser("get", help="Get a version.")
    s.add_argument("labeler_id")
    s.add_argument("version_id")
    s.set_defaults(func=cmd_versions_get)

    s = vsub.add_parser(
        "create",
        help="Snapshot a new version (does not deploy; use 'deploy'). "
        "Uses --criteria if given, otherwise the current draft.",
    )
    s.add_argument("labeler_id")
    s.add_argument(
        "--criteria",
        help="Version criteria text. Omit to snapshot the current draft.",
    )
    s.add_argument("--version-name", dest="version_name")
    s.add_argument("--description")
    s.set_defaults(func=cmd_versions_create)

    s = vsub.add_parser("delete", help="Delete a version.")
    s.add_argument("labeler_id")
    s.add_argument("version_id")
    s.set_defaults(func=cmd_versions_delete)

    # tests
    sp = sub.add_parser("tests", help="Manage test samples (datasets).")
    tsub = sp.add_subparsers(dest="subcommand", required=True)

    s = tsub.add_parser("list", help="List test samples.")
    s.add_argument("labeler_id")
    s.set_defaults(func=cmd_tests_list)

    s = tsub.add_parser("get", help="Get a test sample.")
    s.add_argument("labeler_id")
    s.add_argument("test_id")
    s.set_defaults(func=cmd_tests_get)

    s = tsub.add_parser("create", help="Create test samples.")
    s.add_argument("labeler_id")
    g = s.add_mutually_exclusive_group(required=True)
    g.add_argument("--file", help="JSON file with an array of samples.")
    g.add_argument("--text", help="Single sample content_text.")
    s.add_argument("--label", default="1", choices=["0", "1"], help="expected_label for --text.")
    s.set_defaults(func=cmd_tests_create)

    s = tsub.add_parser(
        "import",
        help=(
            "Bulk-import test samples from a CSV (mirrors the web upload). "
            "Media columns accept http(s) URLs or local file paths."
        ),
    )
    s.add_argument("labeler_id")
    s.add_argument(
        "--csv",
        required=True,
        help=(
            "CSV file. Columns: content_text, content_image_url, "
            "content_video_url, expected_label (required), sample_id."
        ),
    )
    s.add_argument(
        "--dry-run",
        dest="dry_run",
        action="store_true",
        help="Validate the CSV and report counts without downloading or uploading.",
    )
    s.set_defaults(func=cmd_tests_import)

    s = tsub.add_parser("delete", help="Delete a test sample.")
    s.add_argument("labeler_id")
    s.add_argument("test_id")
    s.set_defaults(func=cmd_tests_delete)

    s = tsub.add_parser("delete-all", help="Delete all test samples.")
    s.add_argument("labeler_id")
    s.set_defaults(func=cmd_tests_delete_all)

    # benchmark
    sp = sub.add_parser("benchmark", help="Benchmark a labeler against its stored test samples (build/test; uses /v1, rate-limited).")
    sp.add_argument("labeler_id")
    sp.add_argument("--version", help="Version id, 'draft', or 'latest'. Defaults to your draft (or latest deployed).")
    sp.set_defaults(func=cmd_benchmark)

    # optimize
    sp = sub.add_parser("optimize", help="Run / inspect optimization jobs.")
    osub = sp.add_subparsers(dest="subcommand", required=True)

    s = osub.add_parser("start", help="Start an optimization job.")
    s.add_argument("labeler_id")
    s.add_argument(
        "--tier",
        choices=["basic", "pro", "guru"],
        default="pro",
        help=(
            "Optimizer effort (default: pro). "
            "basic = reformat your labeling criteria (~2 min); "
            "pro = tune to fit your tests (~10 min); "
            "guru = deeply tune with analysis (~30 min). Requires a subscription."
        ),
    )
    s.add_argument("--version", default="draft", help="Version id, 'draft', or 'latest'.")
    s.set_defaults(func=cmd_optimize_start)

    s = osub.add_parser("status", help="Get optimization job status.")
    s.add_argument("labeler_id")
    s.add_argument("job_id", nargs="?", default="latest")
    s.set_defaults(func=cmd_optimize_status)

    s = osub.add_parser("discard", help="Discard an optimization job.")
    s.add_argument("labeler_id")
    s.add_argument("job_id")
    s.set_defaults(func=cmd_optimize_discard)

    # fork
    sp = sub.add_parser("fork", help="Fork/remix a labeler.")
    sp.add_argument("labeler_id")
    sp.add_argument("--name")
    sp.add_argument("--version", default="latest", help="Version id, 'draft', or 'latest'.")
    sp.add_argument("--visibility", choices=["public", "private"])
    sp.add_argument("--clone-tests", dest="clone_tests", action="store_true")
    sp.set_defaults(func=cmd_fork)

    # star
    sp = sub.add_parser("star", help="Star/unstar a labeler (or check status).")
    sp.add_argument("labeler_id")
    sp.add_argument("--status", action="store_true", help="Show status instead of toggling.")
    sp.set_defaults(func=cmd_star)

    # check (single-shot spot check, build-time, via /v1)
    sp = sub.add_parser("check", help="Spot-check a labeler on ad-hoc content without saving it (build/test; uses /v1, rate-limited).")
    sp.add_argument("labeler_id")
    sp.add_argument("--text", help="Content text to spot-check.")
    sp.add_argument("--image", dest="image", help="Image to spot-check: a data URL, remote URL, or local file path.")
    sp.add_argument("--image-url", dest="image", help=argparse.SUPPRESS)
    sp.add_argument("--video", dest="video", help="Video to spot-check: a data URL, remote URL, or local file path.")
    sp.add_argument("--video-url", dest="video", help=argparse.SUPPRESS)
    sp.add_argument("--version", help="Version id, 'draft', or 'latest'. Defaults to your draft (or latest deployed).")
    sp.set_defaults(func=cmd_check)

    # run (single-shot inference)
    sp = sub.add_parser("run", help="Run a labeler on live content you supply (uses the inference API at api.zentropi.ai — use this for production volume).")
    sp.add_argument("labeler_id", nargs="?", default=None, help="Labeler to run. Omit and pass --criteria to label against ad-hoc policy text instead.")
    sp.add_argument("--criteria", help="Ad-hoc policy text to label against, instead of a labeler_id. No labeler needed; nothing is saved.")
    sp.add_argument("--text", help="Content text to label.")
    sp.add_argument("--image", dest="image", help="Image to label: a data URL, remote URL, or local file path.")
    sp.add_argument("--image-url", dest="image", help=argparse.SUPPRESS)
    sp.add_argument("--video", dest="video", help="Video to label: a data URL, remote URL, or local file path.")
    sp.add_argument("--video-url", dest="video", help=argparse.SUPPRESS)
    sp.add_argument("--version", help="labeler_version_id, or 'latest'. Defaults to 'latest' (deployed).")
    sp.add_argument("--model", default="cope-latest")
    sp.set_defaults(func=cmd_label)

    # deploy / undeploy (make a version live for production `run`)
    sp = sub.add_parser(
        "deploy",
        help="Make a labeler live for production. Deploys the current draft, or --version <id>.",
    )
    sp.add_argument("labeler_id")
    sp.add_argument(
        "--version",
        help="Deploy this existing version id instead of snapshotting the draft.",
    )
    sp.set_defaults(func=cmd_deploy)

    sp = sub.add_parser(
        "undeploy",
        help="Take a labeler offline. Undeploys all deployed versions, or --version <id>.",
    )
    sp.add_argument("labeler_id")
    sp.add_argument(
        "--version",
        help="Undeploy this specific version id instead of the live one(s).",
    )
    sp.set_defaults(func=cmd_undeploy)

    return p


def main(argv=None):
    parser = build_parser()
    args = parser.parse_args(argv)
    args.func(args)


if __name__ == "__main__":
    main()
