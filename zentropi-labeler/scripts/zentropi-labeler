#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.8"
# dependencies = ["httpx>=0.24"]
# ///
"""zentropi-labeler — command-line client for the Zentropi labeling platform.

Authentication
--------------
All commands authenticate with a `zt_` API key. The key is resolved in this
order:

    1. --api-key on the command line
    2. ZENTROPI_API_KEY environment variable
    3. the config file written by `zentropi-labeler login` (~/.config/zentropi/config.json)

Endpoints (build vs. run)
-------------------------
Zentropi splits along a build-vs-run line, and so does this CLI:

    * BUILD — create / test / benchmark labelers -> the /v1 API
      (default https://zentropi.ai). Override with ZENTROPI_API_BASE.
    * RUN   — run a labeler on live data -> the inference API
      (default https://api.zentropi.ai). Override with ZENTROPI_INFERENCE_BASE.

`benchmark` (against a labeler's stored dataset) and `check` (a one-off spot
check against ad-hoc content you supply) are both build/test operations, so they
use the /v1 API. `run` executes a labeler against content you supply as a *run*
operation, so it uses the inference API.

For high-volume labeling on live traffic, always use `run` to access the inference API.
By contrast, the `benchmark` and `check` functions are just for testing labelers during development.

The /v1 host 301-redirects app./www. hosts to the naked domain, so requests
follow redirects automatically.

"""

import argparse
import base64
import csv
import getpass
import json
import mimetypes
import os
import sys

import httpx

__version__ = "0.10.1"

DEFAULT_API_BASE = "https://zentropi.ai"
DEFAULT_INFERENCE_BASE = "https://api.zentropi.ai"

CONFIG_DIR = os.path.join(
    os.environ.get("XDG_CONFIG_HOME", os.path.expanduser("~/.config")),
    "zentropi",
)
CONFIG_PATH = os.path.join(CONFIG_DIR, "config.json")


# ----------------------------------------------------------------------------
# Config / key resolution
# ----------------------------------------------------------------------------

def load_config():
    try:
        with open(CONFIG_PATH, "r") as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        return {}


def save_config(cfg):
    os.makedirs(CONFIG_DIR, exist_ok=True)
    with open(CONFIG_PATH, "w") as f:
        json.dump(cfg, f, indent=2)
    try:
        os.chmod(CONFIG_PATH, 0o600)
    except OSError:
        pass


def resolve_api_key(args):
    if getattr(args, "api_key", None):
        return args.api_key
    if os.environ.get("ZENTROPI_API_KEY"):
        return os.environ["ZENTROPI_API_KEY"]
    return load_config().get("api_key")


def api_base():
    return os.environ.get("ZENTROPI_API_BASE", DEFAULT_API_BASE).rstrip("/")


def inference_base():
    return os.environ.get("ZENTROPI_INFERENCE_BASE", DEFAULT_INFERENCE_BASE).rstrip("/")


# ----------------------------------------------------------------------------
# Output helpers
# ----------------------------------------------------------------------------

_NON_JSON = object()


def die(msg, code=1):
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(code)


def require_key(args):
    key = resolve_api_key(args)
    if not key:
        die(
            "no API key found. Run 'zentropi-labeler login zt_...' or set ZENTROPI_API_KEY.",
            code=2,
        )
    return key


def auth_headers(key):
    return {"Authorization": f"Bearer {key}"}


def parse_or_die(resp):
    """Return the JSON body of a response, dying on any error status.

    Returns the special sentinel ``_NON_JSON`` when the (successful) body is not
    JSON so callers can decide how to handle plain-text responses.
    """
    if resp.status_code == 401:
        try:
            detail = resp.json().get("detail", resp.text)
        except Exception:
            detail = resp.text
        die(f"authentication failed (401): {detail}", code=3)

    if resp.status_code >= 400:
        try:
            detail = resp.json().get("detail", resp.text)
        except Exception:
            detail = resp.text
        die(f"request failed ({resp.status_code}): {detail}", code=1)

    try:
        return resp.json()
    except Exception:
        return _NON_JSON


def emit(data, as_json):
    """Print parsed data as JSON or a human-friendly summary."""
    if as_json:
        print(json.dumps(data, indent=2))
    else:
        print(format_human(data))


def handle_response(resp, as_json):
    """Print a response, handling errors (especially 401) gracefully."""
    data = parse_or_die(resp)
    if data is _NON_JSON:
        print(resp.text)
        return
    emit(data, as_json)


def format_human(data):
    if isinstance(data, list):
        if not data:
            return "(empty)"
        lines = []
        for item in data:
            lines.append(_summarize(item))
        return "\n".join(lines)
    return _summarize(data)


def _summarize(item):
    if not isinstance(item, dict):
        return str(item)
    # Prefer a compact id/name summary when present, else pretty JSON.
    if "id" in item and ("name" in item or "email" in item):
        label = item.get("name") or item.get("email") or ""
        return f"{item['id']}  {label}".rstrip()
    return json.dumps(item)


# ----------------------------------------------------------------------------
# HTTP
# ----------------------------------------------------------------------------

def client():
    return httpx.Client(follow_redirects=True, timeout=httpx.Timeout(120.0))


def request(method, path, key, *, json_body=None, params=None):
    url = f"{api_base()}{path}"
    with client() as c:
        return c.request(
            method, url, headers=auth_headers(key), json=json_body, params=params
        )


# ----------------------------------------------------------------------------
# Commands
# ----------------------------------------------------------------------------

def cmd_login(args):
    key = args.key
    if args.key is not None:
        # Passing the key as an argument is convenient for scripts but leaks it
        # into shell history and process listings. Nudge toward safer options.
        print(
            "warning: passing the key on the command line exposes it in your "
            "shell history. Prefer 'zentropi-labeler login' (interactive) or the "
            "ZENTROPI_API_KEY environment variable.",
            file=sys.stderr,
        )
    else:
        try:
            key = getpass.getpass("Enter API key (zt_...): ").strip()
        except (EOFError, KeyboardInterrupt):
            die("login cancelled.")
    if not key:
        die("no API key provided.")
    if not key.startswith("zt_"):
        die("API keys start with 'zt_'.")
    cfg = load_config()
    cfg["api_key"] = key
    save_config(cfg)
    print(f"Saved API key to {CONFIG_PATH}")


def cmd_logout(args):
    cfg = load_config()
    if "api_key" in cfg:
        del cfg["api_key"]
        save_config(cfg)
    print("Logged out.")


def cmd_account(args):
    key = require_key(args)
    handle_response(request("GET", "/v1/account", key), args.json)


def cmd_labelers_list(args):
    key = require_key(args)
    handle_response(
        request("GET", "/v1/labelers", key, params={"skip": args.skip, "limit": args.limit}),
        args.json,
    )


def cmd_labelers_get(args):
    key = require_key(args)
    handle_response(request("GET", f"/v1/labelers/{args.id}", key), args.json)


def cmd_labelers_create(args):
    key = require_key(args)
    body = {}
    if args.name is not None:
        body["name"] = args.name
    if args.description is not None:
        body["description"] = args.description
    if args.criteria is not None:
        body["criteria_text_draft"] = args.criteria
    if args.visibility is not None:
        body["visibility"] = args.visibility
    handle_response(request("POST", "/v1/labelers", key, json_body=body), args.json)


def cmd_labelers_update(args):
    key = require_key(args)
    body = {}
    if args.name is not None:
        body["name"] = args.name
    if args.description is not None:
        body["description"] = args.description
    if args.criteria is not None:
        body["criteria_text_draft"] = args.criteria
    if args.visibility is not None:
        body["visibility"] = args.visibility
    handle_response(request("PUT", f"/v1/labelers/{args.id}", key, json_body=body), args.json)


def cmd_labelers_delete(args):
    key = require_key(args)
    handle_response(request("DELETE", f"/v1/labelers/{args.id}", key), args.json)


def cmd_versions_list(args):
    key = require_key(args)
    handle_response(request("GET", f"/v1/labelers/{args.labeler_id}/versions", key), args.json)


def cmd_versions_get(args):
    key = require_key(args)
    handle_response(
        request("GET", f"/v1/labelers/{args.labeler_id}/versions/{args.version_id}", key),
        args.json,
    )


def cmd_versions_create(args):
    """Snapshot criteria as a new version (does not deploy).

    With --criteria, snapshots the given text. Without it, snapshots the
    labeler's current draft.
    """
    key = require_key(args)
    criteria = args.criteria
    if criteria is None:
        labeler = parse_or_die(request("GET", f"/v1/labelers/{args.labeler_id}", key))
        criteria = (labeler or {}).get("criteria_text_draft") or ""
        if not criteria.strip():
            die(
                "this labeler has no draft criteria to snapshot. Set it with "
                "'zentropi-labeler update <id> --criteria \"...\"' first, "
                "or pass --criteria."
            )
    body = {"criteria_text": criteria}
    if args.version_name is not None:
        body["name"] = args.version_name
    if args.description is not None:
        body["description"] = args.description
    handle_response(
        request("POST", f"/v1/labelers/{args.labeler_id}/versions", key, json_body=body),
        args.json,
    )


def cmd_deploy(args):
    """Make a single version live: the current draft (default) or a given version.

    Deploying snapshots the draft into a new version when no --version is given.
    `run --version latest` always serves the newest version deployed.
    """
    key = require_key(args)
    labeler_id = args.labeler_id

    if args.version:
        target = parse_or_die(request(
            "PUT", f"/v1/labelers/{labeler_id}/versions/{args.version}", key,
            json_body={"is_deployed": True},
        ))
    else:
        labeler = parse_or_die(request("GET", f"/v1/labelers/{labeler_id}", key))
        draft = (labeler or {}).get("criteria_text_draft") or ""
        if not draft.strip():
            die(
                "this labeler has no draft criteria to deploy. Set it with "
                "'zentropi-labeler update <id> --criteria \"...\"' first, or "
                "deploy an existing version with --version <id>."
            )
        target = parse_or_die(request(
            "POST", f"/v1/labelers/{labeler_id}/versions", key,
            json_body={"criteria_text": draft, "is_deployed": True},
        ))

    emit(target, args.json)


def cmd_undeploy(args):
    """Take a labeler offline: undeploy the live version (default) or a given one.

    With no --version, every deployed version is undeployed. After this,
    `run` returns an error until something is deployed again.
    """
    key = require_key(args)
    labeler_id = args.labeler_id

    if args.version:
        target = parse_or_die(request(
            "PUT", f"/v1/labelers/{labeler_id}/versions/{args.version}", key,
            json_body={"is_deployed": False},
        ))
        emit(target, args.json)
        return

    versions = parse_or_die(request("GET", f"/v1/labelers/{labeler_id}/versions", key))
    changed = []
    for v in versions or []:
        if v.get("is_deployed"):
            changed.append(parse_or_die(request(
                "PUT", f"/v1/labelers/{labeler_id}/versions/{v['id']}", key,
                json_body={"is_deployed": False},
            )))
    if not changed:
        emit({"message": "No deployed version; nothing to undeploy."}, args.json)
    else:
        emit(changed, args.json)


def cmd_versions_delete(args):
    key = require_key(args)
    handle_response(
        request("DELETE", f"/v1/labelers/{args.labeler_id}/versions/{args.version_id}", key),
        args.json,
    )


def _load_samples(args):
    if args.file:
        with open(args.file, "r") as f:
            data = json.load(f)
        if not isinstance(data, list):
            die("--file must contain a JSON array of test samples.")
        return data
    if args.text is not None:
        return [{"content_text": args.text, "expected_label": args.label}]
    die("provide either --file or --text/--label.")


def cmd_tests_list(args):
    key = require_key(args)
    handle_response(request("GET", f"/v1/labelers/{args.labeler_id}/tests", key), args.json)


def cmd_tests_get(args):
    key = require_key(args)
    handle_response(
        request("GET", f"/v1/labelers/{args.labeler_id}/tests/{args.test_id}", key), args.json
    )


def cmd_tests_create(args):
    key = require_key(args)
    samples = _load_samples(args)
    handle_response(
        request("POST", f"/v1/labelers/{args.labeler_id}/tests", key, json_body=samples),
        args.json,
    )


# Samples are uploaded in batches so a large dataset (with base64-embedded media)
# never rides in one giant request body.
CSV_IMPORT_BATCH = 10


def _media_to_data_url(ref, kind):
    """Turn a media reference into a base64 data URL the API can store.

    `ref` may be an http(s) URL (downloaded) or a local file path (read from
    disk); an existing `data:` URL is passed through untouched. `kind` is
    'image' or 'video' and only supplies a fallback MIME type. Raises
    ValueError with a readable message on any failure.
    """
    if ref.startswith("data:"):
        return ref
    fallback = "image/jpeg" if kind == "image" else "video/mp4"
    if ref.startswith("http://") or ref.startswith("https://"):
        try:
            with client() as c:
                resp = c.get(ref)
        except httpx.RequestError as e:
            raise ValueError(f"could not download {ref}: {e}")
        if resp.status_code >= 400:
            raise ValueError(f"could not download {ref} (HTTP {resp.status_code})")
        data = resp.content
        mime = resp.headers.get("content-type", "").split(";")[0].strip()
        if not mime or not (mime.startswith("image/") or mime.startswith("video/")):
            mime = mimetypes.guess_type(ref)[0] or fallback
    else:
        path = os.path.expanduser(ref)
        if not os.path.isfile(path):
            raise ValueError(f"file not found: {ref}")
        try:
            with open(path, "rb") as f:
                data = f.read()
        except OSError as e:
            raise ValueError(f"could not read {ref}: {e}")
        mime = mimetypes.guess_type(path)[0] or fallback
    b64 = base64.b64encode(data).decode("ascii")
    return f"data:{mime};base64,{b64}"


def _encode_csv_row(w, n, total, as_json, skipped):
    """Build one test-sample payload from a validated CSV row.

    Downloads/encodes any media into data URLs. On a media failure the row is
    kept as text-only when it has `content_text`, otherwise it is skipped (its
    row number is appended to `skipped`) and None is returned. `n`/`total` drive
    the progress line.
    """
    sample = {"expected_label": w["label"]}
    if w["text"]:
        sample["content_text"] = w["text"]
    if w["sid"]:
        sample["sample_id"] = w["sid"]
    try:
        if w["img"]:
            if not as_json:
                print(
                    f"[{n}/{total}] row {w['row']}: downloading image…",
                    file=sys.stderr,
                )
            sample["content_image"] = _media_to_data_url(w["img"], "image")
        if w["vid"]:
            if not as_json:
                print(
                    f"[{n}/{total}] row {w['row']}: downloading video…",
                    file=sys.stderr,
                )
            sample["content_video"] = _media_to_data_url(w["vid"], "video")
    except ValueError as e:
        if "content_text" in sample:
            print(f"warning: row {w['row']}: {e} — keeping text only.", file=sys.stderr)
            sample.pop("content_image", None)
            sample.pop("content_video", None)
        else:
            print(f"warning: row {w['row']}: {e} — skipping row.", file=sys.stderr)
            skipped.append(w["row"])
            return None
    return sample


def cmd_tests_import(args):
    """Bulk-import test samples from a CSV, mirroring the web upload.

    Recognized columns: content_text, content_image_url, content_video_url,
    expected_label, sample_id. Media columns accept http(s) URLs or local file
    paths; each is downloaded/read and embedded as a data URL, then posted to
    the existing /v1 tests endpoint (which applies the same gating and storage).
    """
    key = require_key(args)
    path = args.csv
    if not os.path.isfile(path):
        die(f"CSV file not found: {path}")
    try:
        with open(path, newline="", encoding="utf-8-sig") as f:
            reader = csv.DictReader(f)
            fieldnames = reader.fieldnames or []
            rows = list(reader)
    except UnicodeDecodeError:
        die("CSV must be UTF-8 encoded.")
    except OSError as e:
        die(f"could not read CSV: {e}")

    has_text = "content_text" in fieldnames
    has_image = "content_image_url" in fieldnames
    has_video = "content_video_url" in fieldnames
    if not (has_text or has_image or has_video):
        die(
            "CSV must have at least one of: content_text, content_image_url, "
            "content_video_url."
        )
    if "expected_label" not in fieldnames:
        die("CSV must have an 'expected_label' column.")

    # Validate structure first (cheap) before downloading anything.
    work = []
    for i, row in enumerate(rows, start=2):  # row 1 is the header
        text = (row.get("content_text") or "").strip() if has_text else ""
        img = (row.get("content_image_url") or "").strip() if has_image else ""
        vid = (row.get("content_video_url") or "").strip() if has_video else ""
        label = (row.get("expected_label") or "").strip()
        sid = (row.get("sample_id") or "").strip()
        if not text and not img and not vid:
            continue  # skip blank rows silently
        if label not in ("0", "1"):
            die(f"row {i}: expected_label must be '0' or '1' (got {label!r}).")
        work.append(
            {"row": i, "text": text, "img": img, "vid": vid, "label": label, "sid": sid}
        )

    if not work:
        die("no usable rows found in CSV.")

    if args.dry_run:
        n_img = sum(1 for w in work if w["img"])
        n_vid = sum(1 for w in work if w["vid"])
        print(
            f"dry run: {len(work)} sample(s) to import "
            f"({n_img} with images, {n_vid} with videos). No data uploaded."
        )
        return

    # Encode + upload one batch at a time so we never hold the whole dataset's
    # base64 media in memory — only the current batch is materialized.
    created = 0
    all_created = []
    skipped = []
    total = len(work)
    for start in range(0, total, CSV_IMPORT_BATCH):
        chunk = work[start : start + CSV_IMPORT_BATCH]
        batch = []
        for offset, w in enumerate(chunk):
            sample = _encode_csv_row(w, start + offset + 1, total, args.json, skipped)
            if sample is not None:
                batch.append(sample)
        if not batch:
            continue
        try:
            resp = request(
                "POST", f"/v1/labelers/{args.labeler_id}/tests", key, json_body=batch
            )
        except httpx.RequestError as e:
            die(
                f"network error during upload at sample {start + 1}: {e} "
                f"({created} created before the failure)"
            )
        if resp.status_code >= 400:
            try:
                detail = resp.json().get("detail", resp.text)
            except Exception:
                detail = resp.text
            if resp.status_code in (401, 402, 403):
                die(
                    f"upload stopped ({resp.status_code}): {detail} "
                    f"({created} created so far)",
                    code=3 if resp.status_code == 401 else 1,
                )
            die(
                f"upload failed at sample {start + 1} ({resp.status_code}): {detail} "
                f"({created} created before the failure)"
            )
        try:
            data = resp.json()
        except Exception:
            data = []
        if isinstance(data, list):
            created += len(data)
            all_created.extend(data)
        if not args.json:
            print(f"uploaded {created}…", file=sys.stderr)

    if created == 0 and not all_created:
        die("no samples were imported (all rows were skipped).")

    if args.json:
        print(json.dumps(all_created, indent=2))
    else:
        msg = f"Imported {created} test sample(s)."
        if skipped:
            msg += (
                f" Skipped {len(skipped)} row(s): "
                f"{', '.join(str(r) for r in skipped)}."
            )
        print(msg)


